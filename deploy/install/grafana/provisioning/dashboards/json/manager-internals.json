{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "uid": "ongrid-manager-internals",
  "title": "Ongrid Manager Internals (ADR-026)",
  "tags": ["ongrid", "self-obs"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Manager up",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"ongrid-manager\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Goroutines",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "go_goroutines{job=\"ongrid-manager\"}", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Heap (MB)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "go_memstats_heap_alloc_bytes{job=\"ongrid-manager\"} / 1024 / 1024", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "type": "stat",
      "title": "Open FDs",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "process_open_fds{job=\"ongrid-manager\"}", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Workers (running)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "ongrid_chatruntime_worker_sessions{status=\"running\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "type": "stat",
      "title": "Edges connected",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "ongrid_edge_connections{status=\"connected\"}", "refId": "A" }]
    },

    {
      "type": "timeseries",
      "title": "HTTP request rate (by status class)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by (status) (rate(ongrid_http_requests_total[5m]))", "refId": "A", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p50/p95/p99",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(ongrid_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ongrid_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(ongrid_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "type": "timeseries",
      "title": "LLM calls (by status)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum by (status) (rate(ongrid_llm_calls_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "LLM error rate (per provider)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        { "expr": "sum by (provider) (rate(ongrid_llm_calls_total{status!=\"ok\"}[5m])) / sum by (provider) (rate(ongrid_llm_calls_total[5m]))", "legendFormat": "{{provider}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "type": "timeseries",
      "title": "LLM latency p95 (per provider)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(ongrid_llm_call_duration_seconds_bucket[5m])))", "legendFormat": "{{provider}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    {
      "type": "timeseries",
      "title": "DB pool",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "ongrid_db_pool_open_connections", "legendFormat": "open", "refId": "A" },
        { "expr": "ongrid_db_pool_in_use", "legendFormat": "in_use", "refId": "B" },
        { "expr": "ongrid_db_pool_idle", "legendFormat": "idle", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB pool wait count (rate)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "rate(ongrid_db_pool_wait_count_total[5m])", "legendFormat": "waits/s", "refId": "A" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Alert evaluator ticks (by status)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "expr": "sum by (status) (rate(ongrid_alert_eval_ticks_total[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "Worker sessions (running/pending)",
      "datasource": { "type": "prometheus", "uid": "ongrid-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "expr": "ongrid_chatruntime_worker_sessions", "legendFormat": "{{status}}", "refId": "A" }
      ]
    }
  ]
}
